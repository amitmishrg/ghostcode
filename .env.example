# Copy to .env in your project or export in your shell.

# Anthropic models (claude-sonnet-4-6, claude-haiku-4-5, claude-opus-4-6)
ANTHROPIC_API_KEY=

# OpenAI models (gpt-5.4, gpt-5.4-mini, gpt-5.4-nano)
OPENAI_API_KEY=

