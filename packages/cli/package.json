{
  "name": "@ghostcode/cli",
  "version": "1.0.0",
  "description": "Provider-agnostic terminal coding harness — local TUI, PLAN/BUILD modes, and your API keys.",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "type": "module",
  "private": false,
  "bin": {
    "ghostcode": "./bin/ghostcode"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "screenshots"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "dev:bin": "GHOSTCODE_DEV=1 bun ./bin/ghostcode",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "pack": "bun pm pack",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@ghostcode/shared": "workspace:1.0.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "@ai-sdk/provider-utils": "^4.0.27",
    "@ai-sdk/react": "^3.0.192",
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
    "ai": "^6.0.190",
    "date-fns": "^4.2.1",
    "dotenv": "^17.4.2",
    "opentui-spinner": "^0.0.6",
    "pretty-ms": "^9.3.0",
    "react": "^19.2.4",
    "react-router": "^7.14.0",
    "zod": "^4.3.6"
  }
}